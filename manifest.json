{
  "manifest_version": 3,
  "name": "全屏截图器",
  "version": "1.0.0",
  "description": "自动滚动截图并拼接长页面",
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://fanqienovel.com/*",
    "https://*.fanqienovel.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://fanqienovel.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
